{
  "name": "@sho-hata/nibble",
  "version": "1.0.0",
  "description": "A CLI tool that randomly surfaces forgotten Chrome bookmarks",
  "author": "sho-hata <syouki100241@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sho-hata/nibble.git"
  },
  "homepage": "https://github.com/sho-hata/nibble#readme",
  "bugs": {
    "url": "https://github.com/sho-hata/nibble/issues"
  },
  "keywords": [
    "bookmarks",
    "chrome",
    "cli",
    "productivity"
  ],
  "engines": {
    "node": ">=18"
  },
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outfile dist/index.js --target node --banner '#!/usr/bin/env node'",
    "prepublishOnly": "bun run build",
    "lint": "oxlint src",
    "fmt": "oxfmt src",
    "fmt:check": "oxfmt --check src"
  },
  "bin": {
    "nibble": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0"
  },
  "dependencies": {
    "@inquirer/checkbox": "^5.1.4"
  }
}
